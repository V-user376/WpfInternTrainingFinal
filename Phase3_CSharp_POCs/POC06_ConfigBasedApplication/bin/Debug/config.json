{
  "appSettings": {
    "ApplicationName": "Task Manager Pro",
    "Version": "33.0",
    "Environment": "Development"
  },
  "databaseConfig": {
    "Provider": "SQLite",
    "ConnectionString": "Data Source=tasks.db",
    "MaxConnections": 10
  },
  "featureFlags": {
    "EnableLogging": true,
    "EnableNotifications": true,
    "EnableAutoSave": true
  },
  "userPreferences": {
    "Theme": "Dark",
    "Language": "English",
    "DateFormat": "yyyy-MM-dd"
  }
}