{
  "appSettings": {
    "ApplicationName": "Task Manager Pro",
    "Version": "ewer",
    "Environment": "Development"
  },
  "databaseConfig": {
    "Provider": "SQLite",
    "ConnectionString": "Data Source=tasks.db",
    "MaxConnections": "10"
  },
  "featureFlags": {
    "EnableLogging": "true",
    "EnableNotifications": "true",
    "EnableAutoSave": "false"
  },
  "userPreferences": {
    "Theme": "Dark",
    "Language": "English",
    "DateFormat": "yyyy-MM-dd"
  }
}