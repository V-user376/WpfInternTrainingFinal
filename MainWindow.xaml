<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Notes"
        Height="450"
        Width="500"
        WindowStartupLocation="Manual"
        Left="1200" Top="500">





    <Grid Margin="10" Background="{DynamicResource BackgroundBrush}">


        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>


        <TextBox Name="TitleBox" KeyDown="TitleTextBox_KeyDown"/>

        <TextBox Name="TitleTextBox"
                 Height="30"
                 Width="380"
                 Margin="0,0,80,10"
                 FontSize="14"
                 VerticalContentAlignment="Center"
                 ToolTip="Enter note title here"
                 KeyDown="TitleTextBox_KeyDown"
                 
                 Background="{DynamicResource BackgroundBrush}"
                 Foreground="{DynamicResource ForegroundBrush}" 
                 
            />
        <TextBlock Text="Enter note title..."
               Margin="5,0,0,0"
               VerticalAlignment="Center"
               Foreground="Gray"
               IsHitTestVisible="False"
               Name="PlaceholderText"
               Visibility="Visible"/>
        

        <Button Name ="ThemeButton"
                Height="30"
                Width="40"
                HorizontalContentAlignment="Right"
                VerticalContentAlignment="Center"
                Margin="400,0,0,10"
                Background="{DynamicResource BackgroundBrush}"
                Foreground="{DynamicResource ForegroundBrush}" 
                Click="ToggleClick"
                Content="Theme"
                />

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox Name="NotesListBox" 
                     Background="{DynamicResource BackgroundBrush}"
                     Foreground="{DynamicResource ForegroundBrush}"
                     SelectionChanged="NotesListBox_SelectionChanged">
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header=" Add to Favorites"
                                  Click="AddToFavorites_Click"/>
                    </ContextMenu>
                </ListBox.ContextMenu>

            </ListBox>

            <TextBox Name="NotesTextBox"
                     Grid.Column="1"                                         
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     
                     TextWrapping="Wrap"
                     Background="{DynamicResource BackgroundBrush}"
                     Foreground="{DynamicResource ForegroundBrush}"
                     FontSize="{DynamicResource AppFontSize}"
                     />


            <ListView x:Name="NotesListView" Width="500" Height="300" Visibility="Collapsed" Grid.ColumnSpan="2" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="File Name" DisplayMemberBinding="{Binding FileName}" Width="300"/>
                        <GridViewColumn Header="Preview" DisplayMemberBinding="{Binding Preview}" Width="150"/>
                        <GridViewColumn Header="Date" DisplayMemberBinding="{Binding Date}" Width="150"/>
                    </GridView>
                </ListView.View>
            </ListView>

        </Grid>
    </Grid>
</Window>
