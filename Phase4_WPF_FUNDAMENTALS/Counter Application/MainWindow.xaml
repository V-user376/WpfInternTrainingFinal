<Window x:Class="Counter_Application.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Counter_Application"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">
    
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Text="Enter a number" Margin="10,14,413,500" />
        <TextBox Margin="118,10,272,500" Width="100" Height="30" Text="{Binding NumberText, UpdateSourceTrigger=PropertyChanged}" />

        <Button Grid.Column="1"            
        Content="Increase Count"
        Command="{Binding IncreaseNumberCommand}"
        Margin="10,0,20,10"
        Height="20"
        Width="120"
        />

        <Button Grid.Column="1"            
        Content="Decrease Count"
        Command="{Binding DecreaseNumberCommand}"
        Margin="10,50,20,10"
        Height="20"
        Width="120"
        />

        <Button Grid.Column="1"            
        Content="Reset"
        Command="{Binding ResetNumberCommand}"
        Margin="10,100,20,10"
        Height="20"
        Width="120"/>

    </Grid>
</Window>
