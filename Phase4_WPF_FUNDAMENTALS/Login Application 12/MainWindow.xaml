<Window x:Class="Login_Application_12.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Login_Application_12"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Enter a number" Margin="11,54,413,320" RenderTransformOrigin="0.738,1.471" />
            <TextBox Grid.Column="0" Margin="80,0,272,300" Width="100" Height="30" Text="{Binding NumberText, UpdateSourceTrigger=PropertyChanged}" RenderTransformOrigin="0.425,-0.616" />
        
        
        </Grid>
</Window>
