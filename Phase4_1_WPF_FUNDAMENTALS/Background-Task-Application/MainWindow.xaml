<Window x:Class="Background_Task_Application.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Background_Task_Application"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />



        </Grid.RowDefinitions>
        
        <Button Content="Insert data in JSON"
                Width="120"
                Height="30"
                Command="{Binding InsertDataCommand}"
                Margin="0,0,0,0"
                Grid.Row="0"
                />

        <TextBlock Text="{Binding Progress, StringFormat={}{0}\%}"
                   Margin="0,0,0,0"
                   Grid.Row="2"                   
                   HorizontalAlignment="Center" />

        <ProgressBar Height="25"
                     Minimum="0"
                     Maximum="100"
                     Value="{Binding Progress}"
                     Width="200"
                     Margin="0,10,0,0"
                     Grid.Row="2"
                     />
        <Button Content="Cancel" 
                Command="{Binding CancelCommand}"
                Grid.Row="3"
                Width="120"
                Margin="0,10,0,10"/>


        <Button Content="Pause"
                Command="{Binding PauseCommand}"
                Grid.Row="4"
                Width="120"
                Margin="0,10,0,10"/>

        <Button Content="Continue"
                Command="{Binding ResumeCommand}"
                Grid.Row="5"
                Width="120"
                Margin="0,10,0,10"/>

    </Grid>
</Window>
