<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Notes"
        Height="450"
        Width="500"
        WindowStartupLocation="Manual"
        Left="1200" Top="500"
        KeyDown="Window_KeyDown">
   
       
        <Window.Resources>

        <Style TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="40" Height="20">

                            <Border x:Name="SwitchTrack"
                            Background="Gray"
                            CornerRadius="15"/>

                            <Ellipse x:Name="SwitchThumb"
                             Width="15"
                             Height="15"
                             Fill="White"
                             Margin="2"
                             HorizontalAlignment="Left"/>

                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="Green"/>
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


    </Window.Resources>

        




        <Grid Margin="10" Background="{DynamicResource BackgroundBrush}">


        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>


        <TextBox Name="TitleBox" KeyDown="TitleTextBox_KeyDown"/>

        <TextBox Name="TitleTextBox"
                 Height="30"
                 Width="380"
                 Margin="0,0,80,10"
                 FontSize="14"
                 VerticalContentAlignment="Center"
                 ToolTip="Enter note title here"
                 KeyDown="TitleTextBox_KeyDown"
                 
                 TextChanged="TitleTextBox_TextChanged"

                 Background="{DynamicResource BackgroundBrush}"
                 Foreground="{DynamicResource ForegroundBrush}" 
                 
            />
        <TextBlock Text="Enter note title..."
               Margin="5,0,0,0"
               VerticalAlignment="Center"
               Foreground="Gray"
               IsHitTestVisible="False"
               Name="PlaceholderText"
               Visibility="Visible"/>


        <ToggleButton x:Name="ThemeToggle"
              Width="60"
              Height="30"
              Margin="400,0,0,10"
              Checked="ThemeToggle_Checked"
              Unchecked="ThemeToggle_Unchecked"
              Background="Transparent"
              BorderThickness="0"/>


        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox Name="NotesListBox" 
                     Background="{DynamicResource BackgroundBrush}"
                     Foreground="{DynamicResource ForegroundBrush}"
                     SelectionChanged="NotesListBox_SelectionChanged">
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header=" Add to Favorites"
                                  Click="AddToFavorites_Click"
                                  />
                        <MenuItem Header=" Remove from Favorites"
                                  Click="RemovefromFavorites"
                                  />
                    </ContextMenu>
                </ListBox.ContextMenu>

            </ListBox>

            <TextBox Name="NotesTextBox"
                     Grid.Column="1"                                         
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     
                     TextWrapping="Wrap"
                     Background="{DynamicResource BackgroundBrush}"
                     Foreground="{DynamicResource ForegroundBrush}"
                     FontSize="{DynamicResource AppFontSize}"
                     />


            <ListView x:Name="NotesListView" Width="500" Height="300" Visibility="Collapsed" Grid.ColumnSpan="2" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="File Name" DisplayMemberBinding="{Binding FileName}" Width="300"/>
                        <GridViewColumn Header="Preview" DisplayMemberBinding="{Binding Preview}" Width="150"/>
                        <GridViewColumn Header="Date" DisplayMemberBinding="{Binding Date}" Width="150"/>
                    </GridView>
                </ListView.View>
            </ListView>

        </Grid>
    </Grid>
</Window>
