<Window x:Class="DataBindingBasics.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DataBindingBasics"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    
    
    
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        
        <DataGrid Grid.Column="0"
              ItemsSource="{Binding Products}"
              SelectedItem="{Binding SelectedProduct}"
              AutoGenerateColumns="False">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" />
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" />


                <DataGridTextColumn Header="Price"
                    Binding="{Binding Price, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <EventSetter Event="PreviewTextInput" Handler="NumberOnly"/>
                            <EventSetter Event="DataObject.Pasting" Handler="NumberOnlyPaste"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>



                <DataGridTextColumn Header="Quantity"
                    Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <EventSetter Event="PreviewTextInput" Handler="NumberOnly"/>
                            <EventSetter Event="DataObject.Pasting" Handler="NumberOnlyPaste"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="TotalValue" Binding="{Binding TotalValue}" />
            </DataGrid.Columns>
        </DataGrid>

        
        <StackPanel Grid.Column="1" Margin="10">

            <TextBox Text="{Binding SelectedProduct.Id, Mode=TwoWay}" Margin="5"/>
            <TextBox Text="{Binding SelectedProduct.Name, Mode=TwoWay}" Margin="5"/>
            <TextBox Text="{Binding SelectedProduct.Price, Mode=TwoWay}" Margin="5"/>
            <TextBox Text="{Binding SelectedProduct.Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="5" PreviewTextInput="NumberOnly" DataObject.Pasting="NumberOnlyPaste"/>
            <TextBox Text="{Binding SelectedProduct.TotalValue, Mode=OneWay}" Margin="5"/>


        </StackPanel>

        <Button Content="Add Product"
                Command="{Binding AddProductCommand}"
                Margin="180,350,20,10"
                Height="20"
                Width="80"
                />

        <Button Content="Remove Product"
        Command="{Binding RemoveProductCommand}"
        Margin="380,350,20,10"
        Height="20"
        Width="100"
        />



    </Grid>

</Window>
