    <Grid Margin="10">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>




        <StackPanel Margin="0,0,0,10">

             
            <TextBlock Text="Title" FontWeight="Bold"/>
            <TextBox Width="200"
             Margin="0,0,0,0"
             Text="{Binding NewTask, UpdateSourceTrigger=PropertyChanged}"/>

             
            <TextBlock Text="Description" FontWeight="Bold"/>
            <TextBox Width="200"
             Margin="0,0,0,0"
             Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>

             
            <TextBlock Text="Due Date" FontWeight="Bold"/>
            <DatePicker Margin="0,0,0,0"
                SelectedDate="{Binding DueDate}"/>

             
            <TextBlock Text="Priority" FontWeight="Bold"/>
            <ComboBox Width="200"
              Margin="0,0,0,0"
              ItemsSource="{Binding Priorities}"
              SelectedItem="{Binding SelectedPriority}"/>

             
            <Button Content="Add Task"
            Width="120"
            Margin="0,10"
            Command="{Binding AddTaskCommand}"/>

            <Button Content="Edit Task"
            Width="120"
            Margin="0,10"
            Command="{Binding UpdateTaskCommand}"/>

            <Button Content="Delete Task"
            Width="120"
            Margin="0,10"
            Command="{Binding DeleteTaskCommand}"/>

            


            


            <TextBlock Text="{Binding Message}"
           Foreground="Red"
           Margin="0,0,0,10"/>


        </StackPanel>


        <DataGrid Grid.Row="1"
          ItemsSource="{Binding Tasks}"
          SelectedItem="{Binding SelectedTask}"
          AutoGenerateColumns="False">

        <DataGrid.Columns>

            <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*" />
            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
            <DataGridTextColumn Header="DueDate" Binding="{Binding DueDate}" Width="*" />
            <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="*" />
            <DataGridTextColumn Header="Complete" Binding="{Binding IsCompleted}" Width="*" />
            <DataGridTextColumn Header="CreatedDate" Binding="{Binding CreatedDate}" Width="*" />
            <DataGridTextColumn Header="CompleteDate" Binding="{Binding CompleteDate}" Width="*" />
            
            </DataGrid.Columns>
    </DataGrid>


</Grid>














</UserControl>

