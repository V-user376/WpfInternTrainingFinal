<UserControl x:Class="Task_Management_Application.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        

        <ToggleButton IsChecked="{Binding DashboardVisible}" 
                      Width="100"
                      Height="30"
                      Content="Toggle"/>

        

        <ToggleButton IsChecked="{Binding IsDarkTheme}"
              Content="Toggle Theme"
              Width="150"
              Height="30"
              Margin="0,100,0,0"/>



    </Grid>
</UserControl>
