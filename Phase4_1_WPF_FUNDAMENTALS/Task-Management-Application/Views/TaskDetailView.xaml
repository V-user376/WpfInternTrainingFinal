<UserControl x:Class="Task_Management_Application.Views.TaskDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="10">

        <!-- 🔍 Search Box -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Width="200"
                 Margin="0,0,10,0"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <Button Content="Search"
                Width="100"
                Command="{Binding SearchCommand}" />

            <Button Content="check"
    Width="100"
    Command="{Binding CheckCommand}" />

        </StackPanel>

        <!-- ❗ Message -->
        <TextBlock Text="{Binding Message}"
               Foreground="Red"
               Margin="0,0,0,10"/>

        <!-- 📊 DataGrid -->
        <DataGrid ItemsSource="{Binding Tasks}"
              AutoGenerateColumns="False">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                <DataGridTextColumn Header="DueDate" Binding="{Binding DueDate}" Width="*" />
                <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="*" />
            </DataGrid.Columns>

        </DataGrid>

    </StackPanel>

</UserControl>

