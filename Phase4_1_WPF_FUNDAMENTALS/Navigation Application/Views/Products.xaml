<UserControl x:Class="Navigation_Application.Views.Products"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Navigation_Application"
        mc:Ignorable="d" Height="450" Width="800">
    <Grid>
        <!--<TextBlock Text="{Binding Title}" FontSize="15" Margin="10"/>-->
        <ListBox ItemsSource="{Binding Products}" Margin="10"/>

        <DataGrid ItemsSource="{Binding Products}"
                  AutoGenerateColumns="False"
                  Margin="10">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="10*"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="30*"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="30*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
