<Window x:Class="WPF_BASIC_FORM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_BASIC_FORM"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="200"/>

        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Name:" />
        <TextBox x:Name="namefield" Grid.Row="0" Grid.Column="1" />

        <Label Grid.Row="1" Grid.Column="0" Content="Email:"/>
        <TextBox x:Name="emailfield" Grid.Row="1" Grid.Column="1"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Phone:"/>
        <TextBox x:Name="phonefield" Grid.Row="2" Grid.Column="1" />

        <Label Grid.Row="3" Grid.Column="0" Content="Address:"/>
        <TextBox x:Name="addressfield" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Visible" />

        <Button Content="Submit" Click="SubmitButton_Click" IsDefault="True" Grid.Row="4" Grid.Column="1"/>
        <Button Content="Clear" Click="ClearButton_Click" IsDefault="True" Grid.Row="5" Grid.Column="1"/>
    
    </Grid>
</Window>

    